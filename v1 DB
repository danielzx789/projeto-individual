
drop database guitarra_db;

create database guitarra_db;
use guitarra_db;

create table usuario (
    id int auto_increment primary key,
    nome varchar(100) not null,
    email varchar(150) not null unique,
    senha varchar(255) not null,
    criado_em datetime default now()
);

create table aulas (
    id int auto_increment primary key,
    titulo varchar(150) not null,
    video_url varchar(255),
    ordem int
);

create table aulas_concluidas (
    usuario_id int not null,
    aula_id int not null,
    data_conclusao datetime default current_timestamp,
    primary key (usuario_id, aula_id),
    constraint fk_progresso_usuario foreign key (usuario_id) references usuario(id),
    constraint fk_progresso_aula foreign key (aula_id) references aulas(id)
);

create table orcamentos (
    id int auto_increment primary key,
    usuario_id int not null,
    tipo_servico varchar(100),
    valor_estimado decimal(10,2),
    data_calculo datetime default current_timestamp,
    constraint fk_orc_usuario foreign key (usuario_id) references usuario(id)
);

